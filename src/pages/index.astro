---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="hero-section gsap-reveal">
    <h1 class="hero-title">Project xp0zure.</h1>
    <p class="hero-subtitle">
      A meticulously curated repository of challenge writeups, geolocation techniques, and architectural cross-referencing.
    </p>
  </div>

  <!-- Infinite Scroll Marquee -->
  <div class="marquee-container">
    <div class="marquee-track">
      <span class="marquee-text">OSINT • COMMUNICATE • RESEARCH • ANALYZE • WRITE • LISTEN • </span>
      <span class="marquee-text">OSINT • COMMUNICATE • RESEARCH • ANALYZE • WRITE • LISTEN • </span>
      <span class="marquee-text">OSINT • COMMUNICATE • RESEARCH • ANALYZE • WRITE • LISTEN • </span>
      <span class="marquee-text">OSINT • COMMUNICATE • RESEARCH • ANALYZE • WRITE • LISTEN • </span>
    </div>
  </div>

  <div class="events-section">
    <div class="section-header gsap-reveal">
      <h2>Captured Events</h2>
      <p class="subtitle">Master directory of compromised CTF infrastructures.</p>
    </div>
    
    <!-- 3D Scroll Gallery -->
    <div class="gallery-pin-container">
      <div class="gallery-perspective">
        <div class="event-list-3d">
          
          <a href="/xp0z-writeups/ramunchers-ctf" class="event-card-3d">
            <div class="event-content">
              <div class="event-title">RAMunchers CTF</div>
              <div class="event-desc">
                Online Jeopardy-style CTF event. Currently securing initial access and documenting active challenge writeups.
              </div>
            </div>
            <div class="event-meta">
              <span class="pill-tag">Ended</span>
              <span class="pill-tag">Team: Rayleigh</span>
              <span class="pill-tag">Rank: 43rd</span>
            </div>
          </a>

          <a href="/xp0z-writeups/cit-ctf" class="event-card-3d">
            <div class="event-content">
              <div class="event-title">CIT@CTF</div>
              <div class="event-desc">
                University of New Haven OSINT challenges. Focuses on social media pivoting, 
                reverse image geolocation, and encrypted document analysis.
              </div>
            </div>
            <div class="event-meta">
              <span class="pill-tag">Ended</span>
              <span class="pill-tag">Team: Rayleigh</span>
              <span class="pill-tag">Rank: 87th</span>
            </div>
          </a>

          <a href="/xp0z-writeups/ctf1" class="event-card-3d">
            <div class="event-content">
              <div class="event-title">CTF 1</div>
              <div class="event-desc">Upcoming security event. Details pending.</div>
            </div>
            <div class="event-meta">
              <span class="pill-tag">Upcoming</span>
            </div>
          </a>

          <a href="/xp0z-writeups/ctf2" class="event-card-3d">
            <div class="event-content">
              <div class="event-title">CTF 2</div>
              <div class="event-desc">Upcoming security event. Details pending.</div>
            </div>
            <div class="event-meta">
              <span class="pill-tag">Upcoming</span>
            </div>
          </a>

          <a href="/xp0z-writeups/ctf3" class="event-card-3d">
            <div class="event-content">
              <div class="event-title">CTF 3</div>
              <div class="event-desc">Upcoming security event. Details pending.</div>
            </div>
            <div class="event-meta">
              <span class="pill-tag">Upcoming</span>
            </div>
          </a>

          <a href="/xp0z-writeups/ctf4" class="event-card-3d">
            <div class="event-content">
              <div class="event-title">CTF 4</div>
              <div class="event-desc">Upcoming security event. Details pending.</div>
            </div>
            <div class="event-meta">
              <span class="pill-tag">Upcoming</span>
            </div>
          </a>

          <a href="/xp0z-writeups/ctf5" class="event-card-3d">
            <div class="event-content">
              <div class="event-title">CTF 5</div>
              <div class="event-desc">Upcoming security event. Details pending.</div>
            </div>
            <div class="event-meta">
              <span class="pill-tag">Upcoming</span>
            </div>
          </a>
          
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .hero-section {
    text-align: center;
    padding: 120px 0 60px;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .hero-title {
    font-size: 5rem;
    line-height: 1.05;
    letter-spacing: -0.05em;
    margin-bottom: 24px;
    color: #000000;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Marquee Styles */
  .marquee-container {
    width: 100vw;
    position: relative;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    background: #000000;
    color: #ffffff;
    padding: 20px 0;
    margin-bottom: 120px;
    display: flex;
    white-space: nowrap;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: scroll-marquee 20s linear infinite;
    will-change: transform;
  }

  .marquee-text {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    padding-right: 2rem;
  }

  @keyframes scroll-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .events-section {
    width: 100vw;
    position: relative;
    margin-left: calc(50% - 50vw);
  }

  .section-header {
    margin-bottom: 20px;
    text-align: center;
  }
  
  .section-header h2 {
    font-size: 2.5rem;
    letter-spacing: -0.04em;
    margin-bottom: 12px;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* 3D Gallery Styles */
  .gallery-pin-container {
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .gallery-perspective {
    width: 100%;
    max-width: 800px;
    height: 250px;
    perspective: 1200px; 
    position: relative;
  }

  .event-list-3d {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
  }
  
  .event-card-3d {
    position: absolute;
    top: 50%; left: 50%;
    width: 100%;
    transform: translate(-50%, -50%) translateZ(-2000px);
    opacity: 0;
    visibility: hidden;
    
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 40px;
    background: #ffffff;
    border-radius: 24px;
    text-decoration: none;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    border: 1px solid var(--border-color);
    will-change: transform, opacity;
  }
  
  .event-content {
    flex: 1;
    padding-right: 40px;
  }

  .event-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .event-desc {
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-end;
  }

  .pill-tag {
    display: inline-block;
    padding: 6px 16px;
    background: var(--btn-secondary-bg);
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pill-tag.active {
    background: rgba(0, 0, 0, 0.9);
    color: #ffffff;
  }
</style>